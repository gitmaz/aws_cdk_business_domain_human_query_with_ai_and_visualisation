# Local: anonymous API + Grafana
VITE_APP_STAGE=local
VITE_API_BASE_URL=https://YOUR_EXECUTE_API_ID.execute-api.ap-southeast-2.amazonaws.com/local

# Non-local (example): OIDC — set issuer + client from your IAM Identity Center app
# VITE_APP_STAGE=dev
# VITE_API_BASE_URL=https://YOUR_API.execute-api.ap-southeast-2.amazonaws.com
# VITE_OIDC_AUTHORITY=https://YOUR_ISSUER
# VITE_OIDC_CLIENT_ID=your-public-client-id
# VITE_OIDC_REDIRECT_URI=http://localhost:3005/
# VITE_OIDC_SCOPE=openid profile email
