# Copy to gitignored files (do not commit copies):
#   .env.local     → npm run spa:dev (LocalStack HttpApiUrl from playwright:print-env)
#   .env.dev       → npm run spa:build:dev
#   .env.test      → npm run spa:build:test
#   .env.prod      → npm run spa:build:prod

# --- .env.local (local FE + LocalStack BE) ---
# VITE_APP_STAGE=local
# VITE_API_BASE_URL=https://YOUR_ID.execute-api.localhost.localstack.cloud:4566/local/

# --- .env.dev ---
# VITE_APP_STAGE=local
# VITE_API_BASE_URL=https://YOUR_DEV_HTTP_API.execute-api.ap-southeast-2.amazonaws.com

# --- .env.test ---
# VITE_APP_STAGE=dev
# VITE_API_BASE_URL=https://YOUR_TEST_HTTP_API.execute-api.ap-southeast-2.amazonaws.com
# VITE_OIDC_AUTHORITY=
# VITE_OIDC_CLIENT_ID=
# VITE_OIDC_REDIRECT_URI=

# --- .env.prod ---
# VITE_APP_STAGE=prod
# VITE_API_BASE_URL=https://YOUR_PROD_HTTP_API.execute-api.ap-southeast-2.amazonaws.com
# VITE_OIDC_AUTHORITY=
# VITE_OIDC_CLIENT_ID=
# VITE_OIDC_REDIRECT_URI=
# VITE_OIDC_SCOPE=openid profile email
